#!/bin/bash

set -euo pipefail

# Positional arguments
DOMAIN="${1:-}"
PORT="${2:-33333}"

# Validate DOMAIN
if [ -z "$DOMAIN" ]; then
  echo "Usage: bash $0 <domain> [port]"
  echo "Example: bash $0 example.com 33333"
  exit 1
fi

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
  echo -e "${GREEN}✓${NC} $1"
}

log_warn() {
  echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
  echo -e "${RED}✗${NC} $1" >&2
}

log_info "Configuring nginx for $DOMAIN on port $PORT"

# Validate template files exist
if [ ! -f ./nginx.template ]; then
  log_error "nginx.template not found in current directory"
  exit 1
fi

if [ ! -f ./websocket.conf ]; then
  log_error "websocket.conf not found in current directory"
  exit 1
fi

# Check if running as root or with sudo
if [ "$EUID" -ne 0 ] && ! sudo -n true 2>/dev/null; then
  log_error "This script requires sudo privileges"
  exit 1
fi

# Install dependencies
log_info "Installing dependencies..."
if command -v apt &> /dev/null; then
  sudo apt update && sudo apt install -y nginx certbot python3-certbot-nginx
elif command -v dnf &> /dev/null; then
  sudo dnf install -y nginx certbot python3-certbot-nginx
elif command -v zypper &> /dev/null; then
  sudo zypper install -y nginx certbot python3-certbot-nginx
elif command -v pacman &> /dev/null; then
  sudo pacman -Sy && sudo pacman -S --noconfirm nginx certbot certbot-nginx
else
  log_error "Unsupported package manager. Please install nginx and certbot manually."
  exit 1
fi

# Configure nginx
log_info "Configuring nginx..."

# Backup existing config if it differs
if [ -f "/etc/nginx/sites-available/$DOMAIN" ]; then
  BACKUP_FILE="/etc/nginx/sites-available/${DOMAIN}.backup.$(date +%s)"
  sudo cp "/etc/nginx/sites-available/$DOMAIN" "$BACKUP_FILE"
  log_warn "Backed up existing config to $BACKUP_FILE"
fi

# Copy and template nginx config
sudo cp ./nginx.template "/etc/nginx/sites-available/$DOMAIN"
sudo sed -i "s|example\.com|${DOMAIN}|g; s|:33333|:${PORT}|g" "/etc/nginx/sites-available/$DOMAIN"
log_info "Nginx config created at /etc/nginx/sites-available/$DOMAIN"

# Create symlink
sudo ln -sf "/etc/nginx/sites-available/$DOMAIN" "/etc/nginx/sites-enabled/$DOMAIN"
log_info "Symlink created in /etc/nginx/sites-enabled/"

# Install websocket config if missing
if [ ! -f /etc/nginx/conf.d/websocket.conf ]; then
  sudo cp ./websocket.conf /etc/nginx/conf.d/websocket.conf
  log_info "WebSocket config installed"
else
  log_warn "WebSocket config already exists, skipping"
fi

# Validate and reload nginx
log_info "Validating nginx config..."
if ! sudo nginx -t; then
  log_error "Nginx config validation failed"
  exit 1
fi

sudo systemctl reload nginx
log_info "Nginx reloaded"

# Obtain SSL certificate
log_info "Obtaining SSL certificate for $DOMAIN..."

if sudo certbot certonly --non-interactive --agree-tos --nginx -d "$DOMAIN" --register-unsafely-without-email; then
  log_info "Certificate obtained successfully"
else
  log_error "Certbot failed. Check /var/log/letsencrypt/letsencrypt.log for details"
  exit 1
fi

# Validate and reload nginx again
log_info "Validating nginx config after certbot..."
if ! sudo nginx -t; then
  log_error "Nginx config validation failed after certbot"
  exit 1
fi

sudo systemctl reload nginx
log_info "Nginx reloaded with SSL config"

log_info "Setup complete! $DOMAIN is now configured with SSL"
log_info "Certificate renewal will run automatically via systemd timer"
