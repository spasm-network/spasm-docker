#!/usr/bin/env bash
# install-podman (final with podman.socket/service enable)
# Usage:
#  sudo bash podman/install-podman            # install for caller (SUDO_USER)
#  sudo bash podman/install-podman alice      # install for specific target user 'alice'
#  sudo TARGET_USER=root bash podman/install-podman  # install for root (advanced/CI)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
AUTO_SCRIPT_SRC="$SCRIPT_DIR/auto-start.sh"
AUTO_SERVICE_SRC="$SCRIPT_DIR/auto-start.service"
AUTO_SCRIPT_DEST_REL=".local/bin/podman-auto-start-spasm.sh"
AUTO_SERVICE_DEST_REL=".config/systemd/user/podman-auto-start-spasm.service"
LOG_PREFIX="[install-podman]"

info() { echo "$LOG_PREFIX $*"; }
err()  { echo "$LOG_PREFIX ERROR: $*" >&2; }

[ "$EUID" -eq 0 ] || { err "Run as root (use sudo)."; exit 1; }

for f in "$AUTO_SCRIPT_SRC" "$AUTO_SERVICE_SRC"; do
  [ -f "$f" ] || { err "Missing: $f"; exit 1; }
done

EXPLICIT_ARG="${1:-}"
if [ -n "$EXPLICIT_ARG" ]; then
  TARGET_USER="$EXPLICIT_ARG"
else
  TARGET_USER="${TARGET_USER:-${SUDO_USER:-}}"
fi

[ -n "$TARGET_USER" ] || { err "Could not determine target user. Use: sudo bash $0 [target_user]"; exit 1; }

if [ "$TARGET_USER" = "root" ]; then
  USER_HOME="$(getent passwd root | cut -d: -f6)"
  USER_UID=0
else
  USER_INFO="$(getent passwd "$TARGET_USER")" || { err "User '$TARGET_USER' not found."; exit 1; }
  USER_HOME="$(echo "$USER_INFO" | cut -d: -f6)"
  USER_UID="$(id -u "$TARGET_USER")"
fi

info "Target: $TARGET_USER (home=$USER_HOME uid=$USER_UID)"

[ -f /etc/os-release ] || { err "/etc/os-release missing"; exit 1; }
. /etc/os-release
DIST="${ID:-unknown}"
ID_LIKE="${ID_LIKE:-}"

pip_hint() {
  local pkg="$1"
  cat <<EOF

Your distro does not provide '$pkg' as a native package.
To install manually via pip (not recommended):

  python3 -m pip install --user $pkg
  sudo pip3 install $pkg

EOF
}

install_pkg_debian() {
  info "apt-get update..."
  apt-get update -y
  apt-get install -y --no-install-recommends podman
  if apt-cache show docker-compose >/dev/null 2>&1; then
    apt-get install -y --no-install-recommends docker-compose
  elif apt-cache show podman-compose >/dev/null 2>&1; then
    apt-get install -y --no-install-recommends podman-compose
  else
    err "No compose package in apt"; pip_hint docker-compose; exit 1
  fi
}

install_pkg_rhel() {
  command -v dnf >/dev/null 2>&1 || { err "dnf not found"; exit 1; }
  dnf -y install podman
  if dnf info docker-compose >/dev/null 2>&1; then
    dnf -y install docker-compose
  elif dnf info docker-compose-plugin >/dev/null 2>&1; then
    dnf -y install docker-compose-plugin
  elif dnf info podman-compose >/dev/null 2>&1; then
    dnf -y install podman-compose
  else
    err "No compose package in dnf"; pip_hint docker-compose; exit 1
  fi
}

install_pkg_arch() {
  pacman -Sy --noconfirm podman
  if pacman -Si docker-compose >/dev/null 2>&1; then
    pacman -S --noconfirm docker-compose
  elif pacman -Si podman-compose >/dev/null 2>&1; then
    pacman -S --noconfirm podman-compose
  else
    err "No compose package in pacman"; pip_hint docker-compose; exit 1
  fi
}

install_pkg_opensuse() {
  zypper --non-interactive refresh
  zypper --non-interactive install podman
  if zypper info docker-compose >/dev/null 2>&1; then
    zypper --non-interactive install docker-compose
  elif zypper info podman-compose >/dev/null 2>&1; then
    zypper --non-interactive install podman-compose
  else
    err "No compose package in zypper"; pip_hint docker-compose; exit 1
  fi
}

dispatch_install() {
  case "$DIST" in
    debian|ubuntu|linuxmint|pop) install_pkg_debian ;;
    fedora|rhel|centos|rocky|almalinux) install_pkg_rhel ;;
    arch|manjaro|endeavouros) install_pkg_arch ;;
    opensuse*|suse) install_pkg_opensuse ;;
    *) 
      if echo "$ID_LIKE" | grep -qi debian; then install_pkg_debian
      elif echo "$ID_LIKE" | grep -Eiq "rhel|fedora"; then install_pkg_rhel
      elif echo "$ID_LIKE" | grep -qi arch; then install_pkg_arch
      elif echo "$ID_LIKE" | grep -qi suse; then install_pkg_opensuse
      else err "Unsupported distro"; exit 1
      fi ;;
  esac
}

# Ensure podman + compose provider present; if not, install via distro packages
COMPOSE_CMD=""
if command -v docker-compose >/dev/null 2>&1; then
  COMPOSE_CMD="docker-compose"
elif command -v podman-compose >/dev/null 2>&1; then
  COMPOSE_CMD="podman-compose"
fi

if ! command -v podman >/dev/null 2>&1 || [ -z "$COMPOSE_CMD" ]; then
  info "Podman or compose provider missing; attempting install via package manager"
  dispatch_install
  # re-evaluate after install
  if command -v docker-compose >/dev/null 2>&1; then
    COMPOSE_CMD="docker-compose"
  elif command -v podman-compose >/dev/null 2>&1; then
    COMPOSE_CMD="podman-compose"
  fi
  if ! command -v podman >/dev/null 2>&1 || [ -z "$COMPOSE_CMD" ]; then
    err "Installation did not provide podman+compose; aborting"
    exit 1
  fi
else
  info "Podman and compose provider present"
fi

# Prepare target user's dirs BEFORE install to avoid transient root-owned parents
if [ "$TARGET_USER" = "root" ]; then
  mkdir -p /root/.local/bin /root/.config/systemd/user
else
  mkdir -p "$USER_HOME/.local/bin" "$USER_HOME/.config/systemd/user"
  chown -R "$TARGET_USER:$TARGET_USER" "$USER_HOME/.local" "$USER_HOME/.config" 2>/dev/null || true
fi

DEST_SCRIPT="$USER_HOME/$AUTO_SCRIPT_DEST_REL"
DEST_SERVICE="$USER_HOME/$AUTO_SERVICE_DEST_REL"

info "Installing files to $DEST_SCRIPT and $DEST_SERVICE"
install -Dm755 "$AUTO_SCRIPT_SRC" "$DEST_SCRIPT"
install -Dm644 "$AUTO_SERVICE_SRC" "$DEST_SERVICE"

# Fix ownership of XDG dirs and installed files (non-root targets)
if [ "$TARGET_USER" != "root" ]; then
  for d in .config .local .cache; do
    [ -e "$USER_HOME/$d" ] && chown -R "$TARGET_USER:$TARGET_USER" "$USER_HOME/$d" 2>/dev/null || true
  done
  chown "$TARGET_USER:$TARGET_USER" "$DEST_SCRIPT" "$DEST_SERVICE" 2>/dev/null || true
else
  chown root:root "$DEST_SCRIPT" "$DEST_SERVICE" 2>/dev/null || true
fi

# Ensure home ownership but don't change perms
[ -d "$USER_HOME" ] && chown "$TARGET_USER:$TARGET_USER" "$USER_HOME" 2>/dev/null || true

# Enable linger and user units (non-root only)
if [ "$TARGET_USER" != "root" ]; then
  info "Enabling linger for $TARGET_USER"
  loginctl enable-linger "$TARGET_USER" || true

  XDG_RUNTIME_DIR="/run/user/$USER_UID"

  # Helper to run a command as the target user with XDG_RUNTIME_DIR set.
  # We attempt to start the user systemd instance via "machinectl --user" fallback:
  run_user() { local cmd="$1"; sudo -u "$TARGET_USER" env XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" bash -lc "$cmd"; }

  info "Reloading user systemd and enabling podman.socket/service + auto-start"

  # Two-phase approach:
  # 1) Try to talk to the user's systemd (works if user instance already running).
  # 2) If that fails, attempt to start a transient user systemd instance via "systemd-run --user --scope"
  #    which will create the user bus and allow enabling sockets/services without an interactive login.
  #
  # Note: systemd-run may not be available in all environments; we try and fall back to instructing the admin.
  set +e
  # First, try the normal enable-now sequence.
  run_user "systemctl --user daemon-reload \
    && systemctl --user enable --now podman.socket || true \
    && systemctl --user enable --now podman.service || true \
    && systemctl --user enable --now podman-auto-start-spasm.service || true"
  rc=$?
  set -e

  if [ $rc -eq 0 ]; then
    info "User systemctl commands executed"
    # Check if podman socket exists; if not, try transient approach
    if [ ! -S "$XDG_RUNTIME_DIR/podman/podman.sock" ]; then
      info "Podman socket not present; attempting transient user scope to initialize user bus"
      set +e
      # Try to create a transient user scope which should spin up the user bus for a moment.
      if command -v systemd-run >/dev/null 2>&1; then
        run_user "systemd-run --user --scope /bin/true" || true
        # Retry enabling/starting services after transient run
        run_user "systemctl --user daemon-reload \
          && systemctl --user enable --now podman.socket || true \
          && systemctl --user enable --now podman.service || true \
          && systemctl --user enable --now podman-auto-start-spasm.service || true" || true
      fi
      set -e
    fi
  else
    err "User systemctl commands failed (user systemd might not be running)."
    echo "Run as $TARGET_USER after login or run the commands below as root to attempt transient start:"
    echo "  sudo -u $TARGET_USER env XDG_RUNTIME_DIR=\"$XDG_RUNTIME_DIR\" systemctl --user daemon-reload"
    echo "  sudo -u $TARGET_USER env XDG_RUNTIME_DIR=\"$XDG_RUNTIME_DIR\" systemctl --user enable --now podman.socket podman.service podman-auto-start-spasm.service"
    if command -v systemd-run >/dev/null 2>&1; then
      echo "Or try (as root) to transiently initialize the user bus and retry enabling:"
      echo "  sudo -u $TARGET_USER env XDG_RUNTIME_DIR=\"$XDG_RUNTIME_DIR\" systemd-run --user --scope /bin/true"
      echo "  sudo -u $TARGET_USER env XDG_RUNTIME_DIR=\"$XDG_RUNTIME_DIR\" systemctl --user enable --now podman.socket podman.service podman-auto-start-spasm.service"
    fi
  fi
else
  info "Target is root: skipping user systemd configuration"
fi

info "Done for $TARGET_USER"
cat <<EOF

User:    $TARGET_USER
Service: podman-auto-start-spasm.service
Script:  $DEST_SCRIPT

If socket didn't start automatically, log in as the target user or run:
  sudo -u $TARGET_USER env XDG_RUNTIME_DIR="/run/user/$USER_UID" systemctl --user enable --now podman.socket
  sudo -u $TARGET_USER env XDG_RUNTIME_DIR="/run/user/$USER_UID" systemctl --user start podman.service

To verify (as root):
  sudo -u $TARGET_USER env XDG_RUNTIME_DIR="/run/user/$USER_UID" systemctl --user status podman.socket podman.service podman-auto-start-spasm.service
  ls -l /run/user/$USER_UID/podman/podman.sock || true
  sudo -u $TARGET_USER env XDG_RUNTIME_DIR="/run/user/$USER_UID" podman info || true

EOF

exit 0
